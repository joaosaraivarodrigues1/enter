        '[qiMpIYAV0m03O4mZ3plXL]:code "GET Disclaimer"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            code: >-
              const pages =
              inputs.pages.value;                                       
                                                                                        
                let idx = -1;   
                for (let i = pages.length - 1; i >= 0; i--) {
                  if (/disclaimer/i.test(pages[i])) {
                    idx = i;
                    break;
                  }
                }

                if (idx === -1) {
                  return {
                    bottom:    { type: 'string',   value: '' },
                    remaining: { type: 'string[]', value: pages },
                  };
                }

                const page     = pages[idx];
                const splitPos = page.search(/disclaimer/i);
                const before   = page.slice(0, splitPos);
                const after    = page.slice(splitPos);

                const bottomParts  = [after, ...pages.slice(idx + 1)].filter(s =>       
                s.trim());
                const prevPages = pages.slice(0, idx);

                if (before.trim() && prevPages.length > 0) {
                  prevPages[prevPages.length - 1] += '\n' + before;
                } else if (before.trim()) {
                  prevPages.push(before); // fallback: disclaimer era a primeira página 
                }

                const remainingArr = prevPages.filter(s => s.trim());

                return {
                  bottom:    { type: 'string',   value: bottomParts.join('\n---\n') },  
                  remaining: { type: 'string[]', value: remainingArr },
                };
            inputNames:
              - pages
            outputNames:
              - bottom
              - remaining
          outgoingConnections:
            - bottom->"Prompt" NDZRb54vRp2Y1yqpLxSVR/input
            - remaining->"Code" 02MizLpi8A_nOffMmDo7o/input
