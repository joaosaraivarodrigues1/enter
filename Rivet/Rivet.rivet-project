          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            code: >-
              const parse = (input) => {
                  const v = input?.value ?? '';
                  if (typeof v !== 'string') return v;
                  let t = v.trim();
                  if (t.startsWith("'")) t = t.slice(1);
                  if (t.endsWith("'"))   t = t.slice(0, -1);
                  t = t.trim();
                  if (!t) return [];
                  try { return JSON.parse(t); } catch(e) {}
                  return t.split('\n').filter(l => l.trim()).map(l => JSON.parse(l.trim()));
                };

                const posicoes     = parse(inputs.posicoes_valorizadas);
                const dadosDesvios = parse(inputs.desvios);
                const ranking      = parse(inputs.ranking_global);
                const desvios      = dadosDesvios.desvios ?? dadosDesvios;

                const recomendacoes = [];

                for (const [classe, desvio] of Object.entries(desvios)) {
                  if (desvio.status !== 'excesso') continue;

                  let saldo = desvio.desvio_brl;
                  const posicoes_classe = posicoes.filter(p => p.classe === classe);
                  const ranking_classe  = ranking[classe] ?? [];

                  const sortKey = (id, nome) => {
                    const idxById   = ranking_classe.indexOf(id);
                    const idxByNome = ranking_classe.indexOf(nome);
                    const idx = idxById !== -1 ? idxById : idxByNome;
                    return idx === -1 ? Infinity : idx;
                  };

                  const ordenadas = [...posicoes_classe].sort((a, b) =>
                    sortKey(b.id, b.nome) - sortKey(a.id, a.nome)
                  );

                  for (const p of ordenadas) {
                    if (saldo <= 0) break;
                    const valor_venda = Math.min(p.valor_atual, saldo);
                    const noRanking   = sortKey(p.id, p.nome) === Infinity;
                    recomendacoes.push({
                      ativo:          p.id,
                      nome:           p.nome ?? p.id,
                      classe,
                      acao:           'VENDER',
                      valor_sugerido: Math.round(valor_venda * 100) / 100,
                      motivo:         noRanking
                                        ? 'ativo não consta no ranking recomendado'
                                        : 'classe em excesso — menor prioridade no ranking',
                    });
                    saldo -= valor_venda;
                  }
                }

                return {
                  output: {
                    type:  'object',
                    value: recomendacoes,
                  },
                };
            inputNames:
              - posicoes_valorizadas
              - desvios
              - ranking_global
            outputNames:
              - output
