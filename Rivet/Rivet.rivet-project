        '[1OTv66nwXR9ZjK-Se2Q8g]:code "Code"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            code: >-
              const parse = (input) => {
                  const v = input?.value ?? '';
                  if (typeof v !== 'string') return Array.isArray(v) ? v : [v];
                  let t = v.trim();
                  if (t.startsWith("'")) t = t.slice(1);
                  if (t.endsWith("'"))   t = t.slice(0, -1);
                  t = t.trim();
                  if (!t) return [];
                  if (t.startsWith('[')) return JSON.parse(t);
                  if (t.startsWith('{')) { try { return JSON.parse(t); } catch(e) {} }
                  return t.split('\n').filter(l => l.trim()).map(l => JSON.parse(l.trim()));
                };

                const posicoes_acoes  = parse(inputs.posicoes_acoes);
                const posicoes_fundos = parse(inputs.posicoes_fundos);
                const posicoes_rf     = parse(inputs.posicoes_rf);
                const precos_acoes    = parse(inputs.precos_acoes);
                const cotas_fundos    = parse(inputs.cotas_fundos);
                const ativos_rf       = parse(inputs.ativos_rf);
                const ativos_fundos   = parse(inputs.ativos_fundos);

                const CLASSE_INDEXACAO = {
                  'pos_fixado_cdi':   'caixa',
                  'pos_fixado_selic': 'caixa',
                  'ipca_mais':        'renda_fixa',
                  'prefixado':        'renda_fixa',
                };
                const CLASSE_CATEGORIA = {
                  'RF DI':           'caixa',
                  'RF Simples':      'caixa',
                  'Multimercado RF': 'renda_fixa',
                  'Multimercado':    'multimercado',
                  'Long Biased':     'multimercado',
                  'FIA':             'renda_variavel',
                };

                const ultimoValor = (serie, chave, valor, campo) => {
                  const registros = serie
                    .filter(r => r[chave] === valor && r.mes)
                    .sort((a, b) => b.mes.localeCompare(a.mes));
                  return registros[0]?.[campo] ?? null;
                };

                const resultado = [];

                for (const p of posicoes_acoes) {
                  const preco = ultimoValor(precos_acoes, 'ticker', p.ticker, 'preco_fechamento');
                  if (preco === null) continue;
                  resultado.push({
                    id:          p.ticker,
                    nome:        p.ticker,
                    classe:      'renda_variavel',
                    tipo:        'acao',
                    valor_atual: p.quantidade * preco,
                  });
                }

                for (const p of posicoes_fundos) {
                  const cota  = ultimoValor(cotas_fundos, 'cnpj', p.cnpj, 'cota_fechamento');
                  const ativo = ativos_fundos.find(f => f.cnpj === p.cnpj);
                  if (cota === null || !ativo?.categoria) continue;
                  resultado.push({
                    id:          p.cnpj,
                    nome:        ativo.nome,
                    classe:      CLASSE_CATEGORIA[ativo.categoria] ?? null,
                    tipo:        'fundo',
                    valor_atual: p.numero_cotas * cota,
                  });
                }

                for (const p of posicoes_rf) {
                  const ativo = ativos_rf.find(a => a.id === p.ativo_id);
                  if (!ativo) continue;
                  resultado.push({
                    id:          ativo.id,
                    nome:        ativo.nome,
                    classe:      CLASSE_INDEXACAO[ativo.indexacao] ?? null,
                    tipo:        'rf',
                    valor_atual: p.valor_aplicado,
                  });
                }

                return {
                  output: {
                    type:  'object',
                    value: resultado.filter(p => p.classe !== null),
                  },
                };
            inputNames:
              - posicoes_acoes
              - posicoes_fundos
              - posicoes_rf
              - precos_acoes
              - cotas_fundos
              - ativos_rf
              - ativos_fundos
            outputNames:
              - output
