        '[HHxjn4HTWHQrl-jsEG5a6]:code "Code"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            code: >-
              // ── Inputs
              ────────────────────────────────────────────────────────────────────           
                const parse = (input) => {                                                                      const v = input?.value ?? '';                                                             
                  if (typeof v !== 'string') return Array.isArray(v) ? v : [v];
                  const t = v.trim();
                  if (!t) return [];
                  if (t.startsWith('[') || t.startsWith('{')) return JSON.parse(t);
                  // NDJSON: um objeto por linha
                  if (t.startsWith('"') || t.startsWith('{"')) {
                    return t.split('\n').filter(l => l.trim()).map(l => JSON.parse(l.trim()));
                  }
                  // Texto simples: uma palavra por linha ("caixa\nrenda_fixa\n...")
                  return t.split('\n').map(l => l.trim()).filter(l => l);
                };

                const ranking_ativos     = parse(inputs.ranking_ativos);
                const ranking_classes    = parse(inputs.ranking_classes);
                const classes_permitidas = parse(inputs.classes_permitidas);

                // ── Passo 1 — filtro de suitability ──────────────────────────────────────────
                const classes_ativas = ranking_classes.filter(c => classes_permitidas.includes(c));

                // ── Passo 2 — monta output na ordem macro ────────────────────────────────────
                const result = {};

                for (const classe of classes_ativas) {
                  const ativos = ranking_ativos[classe];
                  if (ativos && ativos.length > 0) {
                    result[classe] = ativos;
                  }
                }

                // ── Saída ─────────────────────────────────────────────────────────────────────
                return {
                  output: {
                    type: 'object',
                    value: result,
                  },
                };
