            allowRequire: false
            allowRivet: false
            code: >-
              const parse = (input) => {
                const v = input?.value ?? '';

                if (typeof v !== 'string') {
                  return Array.isArray(v) ? v : [v];
                }

                let t = v.trim();

                if (t.startsWith("'")) t = t.slice(1);
                if (t.endsWith("'"))   t = t.slice(0, -1);

                t = t.trim();
                if (!t) return [];

                if (t.startsWith('[')) {
                  return JSON.parse(t);
                }

                if (t.startsWith('{')) {
                  try {
                    return JSON.parse(t);
                  } catch (e) {
                    // fallback para NDJSON
                  }
                }

                return t
                  .split('\n')
                  .filter(l => l.trim())
                  .map(l => JSON.parse(l.trim()));
              };


              // ── Input principal ──────────────────────────────────────────────────────────

              // tenta pelo nome declarado, senão pega o primeiro input disponível

              const raw      = inputs.posicoes_valorizadas ?? Object.values(inputs)[0];

              const posicoes = parse(raw);


              // ── Total da carteira ────────────────────────────────────────────────────────

              const total = posicoes.reduce(
                (acc, p) => acc + p.valor_atual,
                0
              );


              // ── Agregação por classe ─────────────────────────────────────────────────────

              const por_classe = {};


              for (const p of posicoes) {
                if (!por_classe[p.classe]) {
                  por_classe[p.classe] = 0;
                }

                por_classe[p.classe] += p.valor_atual;
              }


              // ── Formatação do resultado ──────────────────────────────────────────────────

              const resultado = {};


              for (const [classe, valor] of Object.entries(por_classe)) {
                resultado[classe] = {
                  valor: Math.round(valor * 100) / 100,
                  percentual: Math.round((valor / total) * 10000) / 100
                };
              }


              // ── Saída ─────────────────────────────────────────────────────────────────────

              return {
                output: {
                  type: 'object',
                  value: {
                    total_carteira: Math.round(total * 100) / 100,
                    por_classe: resultado
                  }
                }
              };
            inputNames:
