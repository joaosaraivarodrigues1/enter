            code: >-
              const parse = (input) => {
                  const v = input?.value ?? '';
                  if (typeof v !== 'string') return v;
                  let t = v.trim();
                  if (t.startsWith("'")) t = t.slice(1);
                  if (t.endsWith("'"))   t = t.slice(0, -1);
                  t = t.trim();
                  if (!t) return [];
                  try { return JSON.parse(t); } catch(e) {}
                  return t.split('\n').filter(l => l.trim()).map(l => JSON.parse(l.trim()));
                };

                const vendas  = parse(inputs.recomendacoes_venda);
                const compras = parse(inputs.recomendacoes_compra);

                const agrupar = (lista) => {
                  const resultado = {};
                  for (const item of lista) {
                    if (!resultado[item.classe]) resultado[item.classe] = [];
                    resultado[item.classe].push(item);
                  }
                  return resultado;
                };

                return {
                  output: {
                    type:  'object',
                    value: {
                      vendas:  agrupar(vendas),
                      compras: agrupar(compras),
                    },
                  },
                };
            inputNames:
