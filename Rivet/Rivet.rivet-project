        '[Vmv5R6XKrEF69Vb9QM-xH]:code "Code"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            code: >-
              const parse = (input) => {
                const v = input?.value ?? '';

                if (typeof v !== 'string') {
                  return v;
                }

                let t = v.trim();

                if (t.startsWith("'")) t = t.slice(1);
                if (t.endsWith("'"))   t = t.slice(0, -1);

                t = t.trim();
                if (!t) return {};

                try {
                  return JSON.parse(t);
                } catch (e) {
                  // fallback: retorna string original
                }

                return t;
              };


              // ── Inputs ───────────────────────────────────────────────────────────────────

              const raw    = inputs.percentual_por_classe ?? Object.values(inputs)[0];

              const dados  = parse(raw);


              const perfil = (inputs.perfil_de_risco?.value ?? '')
                .trim()
                .toLowerCase();

              // ── Dados base ───────────────────────────────────────────────────────────────

              const total_carteira = dados.total_carteira ?? 0;

              const por_classe     = dados.por_classe ?? {};


              // ── Perfis de alocação ───────────────────────────────────────────────────────

              const PERFIS = {
                conservador: {
                  caixa:          { min: 30, alvo: 60, max: 80 },
                  renda_fixa:     { min: 20, alvo: 40, max: 70 },
                  multimercado:   { min: 0,  alvo: 0,  max: 0  },
                  renda_variavel: { min: 0,  alvo: 0,  max: 0  }
                },
                moderado: {
                  caixa:          { min: 10, alvo: 30, max: 50 },
                  renda_fixa:     { min: 30, alvo: 50, max: 70 },
                  multimercado:   { min: 0,  alvo: 20, max: 30 },
                  renda_variavel: { min: 0,  alvo: 0,  max: 0  }
                },
                arrojado: {
                  caixa:          { min: 5,  alvo: 15, max: 30 },
                  renda_fixa:     { min: 15, alvo: 35, max: 55 },
                  multimercado:   { min: 10, alvo: 25, max: 40 },
                  renda_variavel: { min: 5,  alvo: 25, max: 40 }
                },
                agressivo: {
                  caixa:          { min: 0,  alvo: 5,  max: 15 },
                  renda_fixa:     { min: 0,  alvo: 15, max: 30 },
                  multimercado:   { min: 10, alvo: 30, max: 50 },
                  renda_variavel: { min: 25, alvo: 50, max: 70 }
                }
              };


              // ── Seleção do perfil ────────────────────────────────────────────────────────

              const alocacao = PERFIS[perfil] ?? PERFIS.moderado;


              // ── Cálculo de desvios ───────────────────────────────────────────────────────

              const desvios = {};


              for (const classe of [
                'caixa',
                'renda_fixa',
                'multimercado',
                'renda_variavel'
              ]) {
                const { min, alvo, max } = alocacao[classe];

                const atual = por_classe[classe]?.percentual ?? 0;

                const desvio_pp =
                  Math.round((atual - alvo) * 100) / 100;

                const desvio_brl =
                  Math.round((desvio_pp / 100) * total_carteira * 100) / 100;

                const status =
                  atual > max ? 'excesso' :
                  atual < min ? 'deficit' :
                  'ok';

                desvios[classe] = {
                  min,
                  alvo,
                  max,
                  atual,
                  desvio_pp,
                  desvio_brl,
                  status
                };
              }


              // ── Saída ─────────────────────────────────────────────────────────────────────

              return {
                output: {
