        '[S9gxYTnq9e23fevi8KF5K]:code "Code"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            code: >-
              // ── Inputs (parse string → array)
              ────────────────────────────────────────────

              const parse = (input) => {
                const v = input?.value ?? '';

                if (typeof v !== 'string') {
                  return Array.isArray(v) ? v : [v];
                }

                const trimmed = v.trim();
                if (!trimmed) return [];

                // JSON array padrão
                if (trimmed.startsWith('[')) {
                  return JSON.parse(trimmed);
                }

                // NDJSON: um objeto por linha
                return trimmed
                  .split('\n')
                  .filter(l => l.trim())
                  .map(l => JSON.parse(l.trim()));
              };


              // (IMPORTANTE: assumindo que essas variáveis existem no contexto)

              const rf_ativos = parse(inputs.r_ativos_rf);

              const acoes     = parse(inputs.r_ativos_acoes);

              const fundos    = parse(inputs.r_ativos_fundos);

              const precos    = parse(inputs.r_precos_acoes);

              const cotas     = parse(inputs.r_cotas_fundos);

              const macro     = parse(inputs.r_macro);


              // ── Derivações macro ─────────────────────────────────────────────────────────

              const m = [...macro]
                .filter(x => x.mes)
                .sort((a, b) => a.mes.localeCompare(b.mes));

              const cdi_12m =
                m.reduce((acc, x) => acc * (1 + x.cdi_mensal / 100), 1) - 1;

              const ibov_12m =
                m.reduce((acc, x) => acc * (1 + x.ibovespa_retorno_mensal / 100), 1) - 1;

              const ipca_12m =
                m.reduce((acc, x) => acc + x.ipca_mensal, 0);

              const selic_atual =
                m[m.length - 1]?.selic_mensal ?? 0;

              const selic_media3m =
                m.slice(-4, -1)
                 .reduce((a, x) => a + x.selic_mensal, 0) / 3;

              const selic_tend =
                selic_atual > selic_media3m * 1.005 ? 'alta' :
                selic_atual < selic_media3m * 0.995 ? 'baixa' :
                'estavel';

              // ── Score para ativos com histórico ──────────────────────────────────────────

              function calcScore(historico, chave, valor, campoPreco, benchmark) {
                const serie = historico
                  .filter(h => h[chave] === valor && h.mes)
                  .sort((a, b) => a.mes.localeCompare(b.mes));

                if (serie.length < 2) return null;

                const prices = serie.map(h => h[campoPreco]);

                const retornos = prices
                  .slice(1)
                  .map((p, i) => (p / prices[i]) - 1);

                const retorno_12m =
                  (prices[prices.length - 1] / prices[0]) - 1;

                const mean =
                  retornos.reduce((a, b) => a + b, 0) / retornos.length;

                const variance =
                  retornos.reduce(
                    (acc, r) => acc + Math.pow(r - mean, 2),
                    0
                  ) / (retornos.length - 1);

                const vol = Math.sqrt(variance);

                const alpha = retorno_12m - benchmark;

                return vol === 0 ? alpha : alpha / vol;
              }


              // ── Score para RF pura (sem histórico) ───────────────────────────────────────

              function scoreRF(indexacao) {
                if (indexacao === 'pos_fixado_selic') {
                  return selic_tend === 'alta' ? 1 : 0;
                }

                if (indexacao === 'pos_fixado_cdi') {
                  return 0;
                }

                if (indexacao === 'ipca_mais') {
                  return ipca_12m > 5 ? 1 : 0;
                }

                if (indexacao === 'prefixado') {
                  return selic_tend === 'baixa' ? 1 : 0;
                }

                return 0;
              }


              // ── Mapas de classificação ───────────────────────────────────────────────────

              const CLASSE_RF = {
                pos_fixado_cdi:   'caixa',
                pos_fixado_selic: 'caixa',
                ipca_mais:        'renda_fixa',
                prefixado:        'renda_fixa'
              };


              const CLASSE_FUNDO = {
                'RF DI':           'caixa',
                'RF Simples':      'caixa',
                'Multimercado RF': 'renda_fixa',
                'Multimercado':    'multimercado',
                'Long Biased':     'multimercado',
                'FIA':             'renda_variavel'
              };


              // ── Monta listas por classe ──────────────────────────────────────────────────

              const classes = {
                caixa: [],
                renda_fixa: [],
                multimercado: [],
                renda_variavel: []
              };


              // Renda fixa (ativos diretos)

              for (const ativo of rf_ativos) {
                const classe = CLASSE_RF[ativo.indexacao];
                if (!classe) continue;

                classes[classe].push({
                  id: ativo.nome,
                  score: scoreRF(ativo.indexacao)
                });
              }


              // Fundos

              for (const fundo of fundos) {
                if (!fundo.categoria) continue;

                const classe = CLASSE_FUNDO[fundo.categoria];
                if (!classe) continue;

                const benchmark =
                  classe === 'renda_variavel' ? ibov_12m : cdi_12m;

                const score = calcScore(
                  cotas,
                  'cnpj',
                  fundo.cnpj,
                  'cota_fechamento',
                  benchmark
                );

                classes[classe].push({
                  id: fundo.nome,
                  score: score ?? -Infinity
                });
              }


              // Ações

              for (const acao of acoes) {
                const score = calcScore(
                  precos,
                  'ticker',
                  acao.ticker,
                  'preco_fechamento',
                  ibov_12m
                );

                classes.renda_variavel.push({
                  id: acao.ticker,
                  score: score ?? -Infinity
                });
              }


              // ── Ordena e formata saída ───────────────────────────────────────────────────

              const result = {};


              for (const classe of [
                'caixa',
                'multimercado',
                'renda_fixa',
                'renda_variavel'
              ]) {
                result[classe] = classes[classe]
