            code: >-
              const parse = (input) => {
                const v = input?.value ?? '';

                if (typeof v !== 'string') return v;

                let t = v.trim();

                if (t.startsWith("'")) t = t.slice(1);
                if (t.endsWith("'")) t = t.slice(0, -1);

                t = t.trim();

                if (!t) return [];

                try {
                  return JSON.parse(t);
                } catch (e) {}

                return t
                  .split('\n')
                  .filter((l) => l.trim())
                  .map((l) => JSON.parse(l.trim()));
              };


              const posicoes = parse(inputs.posicoes_valorizadas);

              const dadosDesvios = parse(inputs.desvios);

              const ranking = parse(inputs.ranking_global);


              const desvios = dadosDesvios.desvios ?? dadosDesvios;


              const ids_carteira = new Set(posicoes.map((p) => p.id));

              const nomes_carteira = new Set(
                posicoes.map((p) => p.nome).filter(Boolean)
              );


              const estaNaCarteira = (ativo) =>
                ids_carteira.has(ativo) || nomes_carteira.has(ativo);

              const recomendacoes = [];


              for (const [classe, desvio] of Object.entries(desvios)) {
                if (desvio.status !== 'deficit') continue;

                const valor_a_aportar = Math.abs(desvio.desvio_brl);
                const ranking_classe = ranking[classe] ?? [];

                let candidato = null;

                for (const ativo of ranking_classe) {
                  if (estaNaCarteira(ativo)) {
                    candidato = {
                      id: ativo,
                      ja_na_carteira: true,
                    };
                    break;
                  }
                }

                if (!candidato && ranking_classe.length > 0) {
                  candidato = {
                    id: ranking_classe[0],
                    ja_na_carteira: false,
                  };
                }

                if (!candidato) continue;

                recomendacoes.push({
                  ativo: candidato.id,
                  classe,
                  acao: 'COMPRAR',
                  valor_sugerido: Math.round(valor_a_aportar * 100) / 100,
                  ja_na_carteira: candidato.ja_na_carteira,
                  motivo: candidato.ja_na_carteira
                    ? 'classe em deficit — aumentar posição existente de maior prioridade'
                    : 'classe em deficit — abrir nova posição no ativo de maior prioridade',
                });
              }


              return {
                output: {
                  type: 'object',
                  value: recomendacoes,
                },
              };
            inputNames:
